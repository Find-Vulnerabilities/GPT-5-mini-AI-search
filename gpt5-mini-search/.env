# OpenAI API Configuration (if using official API)
# Important: Make sure you have available credits/quota on your OpenAI account
# Check: https://platform.openai.com/account/billing/overview
OPENAI_API_KEY=your_openai_api_key_here

# GitHub Copilot Token (free alternative - get from GitHub)
# Note: Must be a Copilot-specific token, NOT a Personal Access Token
# Request access: https://github.com/github-copilot/signups
GITHUB_TOKEN=your_github_copilot_token_here

# Free Search APIs (choose one)
BRAVE_SEARCH_API_KEY=your_brave_key_here  # Free tier: 2000 requests/month
DUCKDUCKGO_SEARCH_ENABLED=true                 # Completely free, no API key needed

# Application Settings
MAX_SEARCH_RESULTS=5
CACHE_TTL=3600  # Cache search results for 1 hour
RATE_LIMIT_REQUESTS=50  # GitHub Copilot free tier limit
RATE_LIMIT_WINDOW=30    # Per 30 days